---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPaletteById, palettes } from "../../lib/palettes";
import { getSimilarPalettes } from "../../lib/palette-utils";
import { ArrowLeft } from "lucide-react";
import { siteConfig } from "../../lib/site";
import PaletteColorSection from "../../components/PaletteColorSection.astro";
import PaletteDetailHeader from "../../components/PaletteDetailHeader.astro";
import PaletteExportSection from "../../components/PaletteExportSection.astro";
import PalettePreviewSection from "../../components/PalettePreviewSection.astro";
import SimilarPalettesSection from "../../components/SimilarPalettesSection.astro";

export function getStaticPaths() {
  return palettes.map((palette) => ({
    params: { id: palette.id },
  }));
}

const { id } = Astro.params;
const palette = getPaletteById(id!);

if (!palette) {
  return new Response(null, { status: 404 });
}

const similarPalettes = getSimilarPalettes(palette);
---

<BaseLayout title={`${palette.name} - SciPalette`} description={palette.description}>
  <>
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="sp-reveal mb-7">
        <a href={`${siteConfig.basePath}/palettes/`} class="inline-flex items-center gap-2 text-sm font-bold text-[rgb(33_44_51_/_0.66)] transition-colors hover:text-[#212c33]">
          <ArrowLeft class="w-4 h-4" />
          Back to all palettes
        </a>
      </div>
      <div class="space-y-12">
        <PaletteDetailHeader palette={palette} />
        <PaletteColorSection palette={palette} />
        <PalettePreviewSection palette={palette} />
        <PaletteExportSection palette={palette} />
        <SimilarPalettesSection palettes={similarPalettes} />
      </div>
    </main>
  </>
</BaseLayout>
