---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPaletteById, palettes } from "../../lib/palettes";
import { getSimilarPalettes } from "../../lib/palette-utils";
import { BadgeList } from "../../components/BadgeList";
import { ColorSwatch } from "../../components/ColorSwatch";
import { PlotPreview } from "../../components/PlotPreview";
import { CodeExport } from "../../components/CodeExport";
import PaletteGrid from "../../components/PaletteGrid";
import { ArrowLeft, Check } from "lucide-react";

export function getStaticPaths() {
  return palettes.map((palette) => ({
    params: { id: palette.id },
  }));
}

const { id } = Astro.params;
const palette = getPaletteById(id!);

if (!palette) {
  return new Response(null, { status: 404 });
}

const similarPalettes = getSimilarPalettes(palette);
---

<BaseLayout title={`${palette.name} - SciPalette`} description={palette.description}>
  <div class="min-h-screen bg-white">
    <!-- Header -->
    <header class="border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <a href="/SciPalette/" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 transition-colors">
          <ArrowLeft class="w-4 h-4" />
          Back to all palettes
        </a>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="space-y-12">
        <!-- Palette Header -->
        <div>
          <div class="flex items-start justify-between gap-4 mb-4">
            <div>
              <h1 class="text-4xl font-bold text-gray-900 mb-2">{palette.name}</h1>
              <p class="text-lg text-gray-600">{palette.description}</p>
            </div>
            {palette.colorblindSafe && (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-green-100 text-green-700 shrink-0">
                <Check class="w-4 h-4" />
                Colorblind Safe
              </span>
            )}
          </div>

          <!-- Metadata -->
          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 mb-6">
            <span class="capitalize font-medium">{palette.category}</span>
            <span>•</span>
            <span>{palette.colors.length} colors</span>
            <span>•</span>
            <span class="capitalize">Best on {palette.background} background</span>
            {palette.source && (
              <>
                <span>•</span>
                <span class="text-gray-500">{palette.source}</span>
              </>
            )}
          </div>

          <!-- Tags -->
          {palette.recommendedFor.length > 0 && (
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-700 mb-2">Recommended for:</h3>
              <BadgeList items={palette.recommendedFor} client:load />
            </div>
          )}

          {palette.tags.length > 0 && (
            <div>
              <h3 class="text-sm font-medium text-gray-700 mb-2">Tags:</h3>
              <BadgeList items={palette.tags} variant="default" client:load />
            </div>
          )}
        </div>

        <!-- Color Strip -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Colors</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {palette.colors.map((color, index) => (
              <ColorSwatch color={color} showDetails client:visible />
            ))}
          </div>
        </div>

        <!-- Plot Previews -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Preview in Scientific Plots</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {palette.recommendedFor.includes("bar") && (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <h3 class="text-sm font-medium text-gray-700 mb-3">Bar Plot</h3>
                <PlotPreview palette={palette} type="bar" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("line") && (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <h3 class="text-sm font-medium text-gray-700 mb-3">Line Plot</h3>
                <PlotPreview palette={palette} type="line" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("scatter") && (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <h3 class="text-sm font-medium text-gray-700 mb-3">Scatter Plot</h3>
                <PlotPreview palette={palette} type="scatter" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("umap") && (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <h3 class="text-sm font-medium text-gray-700 mb-3">UMAP</h3>
                <PlotPreview palette={palette} type="umap" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("heatmap") && (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <h3 class="text-sm font-medium text-gray-700 mb-3">Heatmap</h3>
                <PlotPreview palette={palette} type="heatmap" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("volcano") && (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <h3 class="text-sm font-medium text-gray-700 mb-3">Volcano Plot</h3>
                <PlotPreview palette={palette} type="volcano" client:visible />
              </div>
            )}
          </div>
        </div>

        <!-- Code Export -->
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
          <CodeExport palette={palette} client:visible />
        </div>

        <!-- Similar Palettes -->
        {similarPalettes.length > 0 && (
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Similar Palettes</h2>
            <PaletteGrid palettes={similarPalettes} client:visible />
          </div>
        )}
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <p class="text-center text-sm text-gray-500">
          SciPalette · A curated collection of scientific color palettes
        </p>
      </div>
    </footer>
  </div>
</BaseLayout>
