---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPaletteById, palettes } from "../../lib/palettes";
import { getSimilarPalettes } from "../../lib/palette-utils";
import { BadgeList } from "../../components/BadgeList";
import { ColorSwatch } from "../../components/ColorSwatch";
import { PlotPreview } from "../../components/PlotPreview";
import { CodeExport } from "../../components/CodeExport";
import PaletteGrid from "../../components/PaletteGrid";
import { ArrowLeft, Check } from "lucide-react";

export function getStaticPaths() {
  return palettes.map((palette) => ({
    params: { id: palette.id },
  }));
}

const { id } = Astro.params;
const palette = getPaletteById(id!);

if (!palette) {
  return new Response(null, { status: 404 });
}

const similarPalettes = getSimilarPalettes(palette);
---

<BaseLayout title={`${palette.name} - SciPalette`} description={palette.description}>
  <div class="min-h-screen text-[#212c33]">
    <header class="border-b border-[#dadcd6] bg-[rgb(251_249_242_/_0.72)] backdrop-blur">
      <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
        <a href="/SciPalette/" class="inline-flex items-center gap-2 rounded-[14px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.86)] px-3 py-1.5 text-sm font-bold text-[#212c33] transition-colors hover:bg-[rgb(122_158_141_/_0.12)]">
          <ArrowLeft class="w-4 h-4" />
          Back to all palettes
        </a>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="space-y-12">
        <div class="rounded-[20px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.82)] p-6 shadow-[0_24px_70px_rgb(33_44_51_/_0.06)] sm:p-8">
          <div class="mb-5 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="mb-2 text-xs font-bold uppercase tracking-[0.16em] text-[#4f6d5f]">palette detail</p>
              <h1 class="font-display text-5xl font-bold tracking-[-0.04em] text-[#212c33] sm:text-6xl">{palette.name}</h1>
              <p class="mt-3 max-w-3xl text-lg leading-8 text-[rgb(33_44_51_/_0.72)]">{palette.description}</p>
            </div>
            {palette.colorblindSafe && (
              <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-[rgb(79_109_95_/_0.26)] bg-[rgb(122_158_141_/_0.16)] px-3 py-1.5 text-sm font-bold text-[#2f453d]">
                <Check class="w-4 h-4" />
                Colorblind Safe
              </span>
            )}
          </div>

          <div class="mb-6 flex flex-wrap items-center gap-3 text-sm font-semibold text-[rgb(33_44_51_/_0.66)]">
            <span class="capitalize font-medium">{palette.category}</span>
            <span class="h-1 w-1 rounded-full bg-[#4f6d5f]"></span>
            <span>{palette.colors.length} colors</span>
            <span class="h-1 w-1 rounded-full bg-[#4f6d5f]"></span>
            <span class="capitalize">Best on {palette.background} background</span>
            {palette.source && (
              <>
                <span class="h-1 w-1 rounded-full bg-[#4f6d5f]"></span>
                <span class="text-[rgb(33_44_51_/_0.56)]">{palette.source}</span>
              </>
            )}
          </div>

          {palette.recommendedFor.length > 0 && (
            <div class="mb-4">
              <h3 class="mb-2 text-xs font-bold uppercase tracking-[0.14em] text-[rgb(33_44_51_/_0.66)]">Recommended for</h3>
              <BadgeList items={palette.recommendedFor} client:load />
            </div>
          )}

          {palette.tags.length > 0 && (
            <div>
              <h3 class="mb-2 text-xs font-bold uppercase tracking-[0.14em] text-[rgb(33_44_51_/_0.66)]">Tags</h3>
              <BadgeList items={palette.tags} variant="default" client:load />
            </div>
          )}
        </div>

        <div>
          <h2 class="font-display mb-4 text-4xl font-bold tracking-[-0.02em] text-[#212c33]">Colors</h2>
          <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
            {palette.colors.map((color, index) => (
              <ColorSwatch color={color} showDetails client:visible />
            ))}
          </div>
        </div>

        <div>
          <h2 class="font-display mb-4 text-4xl font-bold tracking-[-0.02em] text-[#212c33]">Preview in scientific plots</h2>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
            {palette.recommendedFor.includes("bar") && (
              <div class="rounded-[18px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.76)] p-6 shadow-sm">
                <h3 class="mb-3 text-sm font-bold text-[#212c33]">Bar Plot</h3>
                <PlotPreview palette={palette} type="bar" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("line") && (
              <div class="rounded-[18px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.76)] p-6 shadow-sm">
                <h3 class="mb-3 text-sm font-bold text-[#212c33]">Line Plot</h3>
                <PlotPreview palette={palette} type="line" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("scatter") && (
              <div class="rounded-[18px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.76)] p-6 shadow-sm">
                <h3 class="mb-3 text-sm font-bold text-[#212c33]">Scatter Plot</h3>
                <PlotPreview palette={palette} type="scatter" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("umap") && (
              <div class="rounded-[18px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.76)] p-6 shadow-sm">
                <h3 class="mb-3 text-sm font-bold text-[#212c33]">UMAP</h3>
                <PlotPreview palette={palette} type="umap" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("heatmap") && (
              <div class="rounded-[18px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.76)] p-6 shadow-sm">
                <h3 class="mb-3 text-sm font-bold text-[#212c33]">Heatmap</h3>
                <PlotPreview palette={palette} type="heatmap" client:visible />
              </div>
            )}
            {palette.recommendedFor.includes("volcano") && (
              <div class="rounded-[18px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.76)] p-6 shadow-sm">
                <h3 class="mb-3 text-sm font-bold text-[#212c33]">Volcano Plot</h3>
                <PlotPreview palette={palette} type="volcano" client:visible />
              </div>
            )}
          </div>
        </div>

        <div class="rounded-[20px] border border-[#dadcd6] bg-[rgb(251_249_242_/_0.82)] p-6 shadow-[0_22px_70px_rgb(33_44_51_/_0.06)] sm:p-8">
          <CodeExport palette={palette} client:visible />
        </div>

        {similarPalettes.length > 0 && (
          <div>
            <h2 class="font-display mb-6 text-4xl font-bold tracking-[-0.02em] text-[#212c33]">Similar palettes</h2>
            <PaletteGrid palettes={similarPalettes} client:visible />
          </div>
        )}
      </div>
    </main>

    <footer class="mt-16 border-t border-[#dadcd6] bg-[rgb(251_249_242_/_0.62)]">
      <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <p class="text-center text-sm font-medium text-[rgb(33_44_51_/_0.58)]">
          SciPalette, a curated collection of scientific color palettes.
        </p>
      </div>
    </footer>
  </div>
</BaseLayout>
