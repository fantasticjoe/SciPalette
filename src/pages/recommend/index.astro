---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PaletteRecommendationPanel } from "../../components/PaletteRecommendationPanel";
---

<BaseLayout
  title="Palette Recommendation - SciPalette"
  description="A browser-local recommendation assistant that matches SciPalette color palettes to scientific plot intent, palette family, color count, background, and accessibility needs."
>
  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <PaletteRecommendationPanel client:load />
  </main>
</BaseLayout>
