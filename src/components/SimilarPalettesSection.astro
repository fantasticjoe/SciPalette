---
import { GitCompare } from "lucide-react";
import PaletteGrid from "./PaletteGrid";
import type { Palette } from "../lib/types";

interface Props {
  palettes: Palette[];
}

const { palettes } = Astro.props;
---

{palettes.length > 0 && (
  <section class="sp-reveal sp-reveal-delay-2">
    <h2 class="font-display mb-6 inline-flex items-center gap-2 text-4xl font-bold tracking-[-0.02em] text-[#212c33]">
      <GitCompare class="h-6 w-6 text-[#4f6d5f]" aria-hidden="true" />
      Similar palettes
    </h2>
    <PaletteGrid palettes={palettes} client:visible />
  </section>
)}
